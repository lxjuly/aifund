---
import { marketBars } from "../data/market-bars";

const sql = `SELECT timestamp, close
FROM market_bars
WHERE symbol = 'US.NVDA' AND timeframe = 'K_DAY'
ORDER BY timestamp`;

const closes = marketBars.map((bar) => bar.close);
const minClose = Math.min(...closes);
const maxClose = Math.max(...closes);
const chartWidth = 640;
const chartHeight = 320;
const chartPadding = 36;
const chartRange = maxClose - minClose || 1;
const chartPoints = marketBars.map((bar, index) => {
  const x = chartPadding + (index / (marketBars.length - 1)) * (chartWidth - chartPadding * 2);
  const y = chartHeight - chartPadding - ((bar.close - minClose) / chartRange) * (chartHeight - chartPadding * 2);

  return {
    ...bar,
    x,
    y,
  };
});
const chartPath = chartPoints.map((point, index) => `${index === 0 ? "M" : "L"} ${point.x} ${point.y}`).join(" ");
---

<section class="chart-lab" aria-label="SQLPrism chart prototype">
  <div class="chart-copy">
    <p class="eyebrow">SQLPrism prototype</p>
    <h2>SQL becomes a chart grammar. The backend only returns rows.</h2>
    <pre><code>{sql}</code></pre>
  </div>
  <div class="chart-frame">
    <div id="sqlprism-price-chart" data-sql={sql} data-rows={JSON.stringify(marketBars)}>
      <svg
        class="fixture-chart"
        viewBox={`0 0 ${chartWidth} ${chartHeight}`}
        role="img"
        aria-label="NVDA close price fixture line chart"
      >
        <line
          x1={chartPadding}
          x2={chartPadding}
          y1={chartPadding}
          y2={chartHeight - chartPadding}
        />
        <line
          x1={chartPadding}
          x2={chartWidth - chartPadding}
          y1={chartHeight - chartPadding}
          y2={chartHeight - chartPadding}
        />
        <path d={chartPath} />
        {chartPoints.map((point) => (
          <g>
            <circle cx={point.x} cy={point.y} r="4" />
            <title>{`${point.timestamp}: ${point.close}`}</title>
          </g>
        ))}
      </svg>
      <div class="chart-enhancement" aria-hidden="true"></div>
      <p class="chart-status" role="status" aria-live="polite"></p>
    </div>
  </div>
</section>

<script>
  import { refractSqlToVega } from "../utils/sqlprism-adapter";
  import type { VisualizationSpec } from "vega-embed";
  import embed from "vega-embed";

  const target = document.querySelector<HTMLElement>("#sqlprism-price-chart");

  async function renderChart() {
    if (!target) {
      return;
    }

    const sql = target.dataset.sql ?? "";
    const rows = JSON.parse(target.dataset.rows ?? "[]");
    const { vega } = refractSqlToVega(sql);

    try {
      if (!vega) {
        throw new Error("No Vega-Lite spec generated for SQL.");
      }

      const mark = vega.mark === "line" || vega.mark === "bar" || vega.mark === "point"
        ? vega.mark
        : "point";
      const spec = {
        ...vega,
        width: Math.max(target.clientWidth - 32, 320),
        height: 320,
        title: "NVDA close price fixture",
        data: { values: rows },
        mark: { type: mark, tooltip: true },
      } as unknown as VisualizationSpec;

      const enhancementTarget = target.querySelector<HTMLElement>(".chart-enhancement");

      if (!enhancementTarget) {
        throw new Error("Chart enhancement target was not found.");
      }

      const result = await embed(enhancementTarget, spec, { actions: false, renderer: "svg" });
      const renderedSvg = enhancementTarget.querySelector("svg");

      if (!renderedSvg) {
        result.finalize();
        throw new Error("Vega did not render an SVG.");
      }

      target.classList.add("is-enhanced");
      enhancementTarget.removeAttribute("aria-hidden");
    } catch (error) {
      const status = target.querySelector<HTMLElement>(".chart-status");

      if (status) {
        target.classList.add("has-chart-error");
        status.textContent = error instanceof Error
          ? `Vega enhancement failed: ${error.message}`
          : "Vega enhancement failed.";
      }
    }
  }

  renderChart();
</script>
