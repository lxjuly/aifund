<section class="demo-band" id="demo">
  <div class="section-heading">
    <p class="eyebrow">Live governed demo</p>
    <h2>Intent to recommendation, with a trace.</h2>
    <p>
      This demo calls the deployed <code>/api/analyze</code> endpoint and shows how
      AIfund turns a research intent into a semantic plan, validates it through a
      governed dry run, and returns a provenance-backed recommendation.
    </p>
  </div>

  <div class="demo-shell">
    <form class="demo-form" id="governed-demo-form">
      <label>
        Research intent
        <textarea id="demo-intent" name="intent" rows="4">Find attractive NVDA alternatives</textarea>
      </label>
      <label>
        Subject
        <input id="demo-subject" name="subject" value="NVDA" />
      </label>
      <button class="button primary" type="submit">Run governed analysis</button>
      <p class="demo-status" id="demo-status">Ready to run semantic planning and policy validation.</p>
    </form>

    <div class="demo-output" id="demo-output" aria-live="polite">
      <article class="demo-card placeholder">
        <h3>Pipeline output</h3>
        <p>Run the demo to visualize the semantic plan, dry-run validation, recommendation, and provenance trace.</p>
      </article>
    </div>
  </div>
</section>

<script>
  type DemoResponse = {
    semanticPlan: {
      intent: string;
      subject: string;
      agents: string[];
    };
    dryRun: {
      approved: boolean;
      policyChecks: string[];
      entitiesTouched: string[];
    };
    recommendation: {
      asset: string;
      score: number;
      rationale: string;
      provenance: string[];
    };
  };

  const form = document.querySelector<HTMLFormElement>("#governed-demo-form");
  const output = document.querySelector<HTMLDivElement>("#demo-output");
  const status = document.querySelector<HTMLParagraphElement>("#demo-status");
  const intentInput = document.querySelector<HTMLTextAreaElement>("#demo-intent");
  const subjectInput = document.querySelector<HTMLInputElement>("#demo-subject");

  const escapeHtml = (value: unknown): string => String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");

  const chips = (items: string[] = []): string => items
    .map((item) => `<span class="demo-chip">${escapeHtml(item)}</span>`)
    .join("");

  const render = (data: DemoResponse): void => {
    if (!output) return;

    const plan = data.semanticPlan;
    const dryRun = data.dryRun;
    const rec = data.recommendation;

    output.innerHTML = `
      <article class="demo-card">
        <div class="demo-card-head">
          <h3>Semantic plan</h3>
          <span>planned</span>
        </div>
        <p><strong>Intent:</strong> ${escapeHtml(plan.intent)}</p>
        <p><strong>Subject:</strong> ${escapeHtml(plan.subject)}</p>
        <div class="demo-chip-group">${chips(plan.agents)}</div>
      </article>

      <article class="demo-card">
        <div class="demo-card-head">
          <h3>Governed dry run</h3>
          <span>${dryRun.approved ? "approved" : "blocked"}</span>
        </div>
        <p><strong>Policy checks</strong></p>
        <div class="demo-chip-group">${chips(dryRun.policyChecks)}</div>
        <p><strong>Entities touched</strong></p>
        <div class="demo-chip-group">${chips(dryRun.entitiesTouched)}</div>
      </article>

      <article class="demo-card recommendation-card">
        <div class="demo-card-head">
          <h3>Recommendation</h3>
          <span>selected</span>
        </div>
        <div class="recommendation-score">${escapeHtml(rec.asset)} · ${Math.round(rec.score * 100)}%</div>
        <p>${escapeHtml(rec.rationale)}</p>
      </article>

      <article class="demo-card">
        <div class="demo-card-head">
          <h3>Provenance trace</h3>
          <span>traceable</span>
        </div>
        <div class="demo-chip-group">${chips(rec.provenance)}</div>
      </article>
    `;
  };

  const setStatus = (message: string): void => {
    if (status) status.textContent = message;
  };

  const runDemo = async (): Promise<void> => {
    if (!intentInput || !subjectInput) {
      setStatus("Demo form is not available.");
      return;
    }

    setStatus("Running semantic planning and governed dry run...");
    try {
      const response = await fetch("/api/analyze", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({
          intent: intentInput.value,
          subject: subjectInput.value,
        }),
      });

      if (!response.ok) {
        throw new Error(`API returned ${response.status}`);
      }

      const data = (await response.json()) as DemoResponse;
      render(data);
      setStatus("Completed. Recommendation generated with governed provenance.");
    } catch (error: unknown) {
      const message = error instanceof Error ? error.message : String(error);
      setStatus(`Demo failed: ${message}`);
    }
  };

  form?.addEventListener("submit", (event: SubmitEvent) => {
    event.preventDefault();
    void runDemo();
  });
</script>
