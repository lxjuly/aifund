---
import BaseLayout from "../layouts/BaseLayout.astro";
import SystemVisual from "../components/SystemVisual.astro";
import GovernedDemo from "../components/GovernedDemo.astro";
---

<BaseLayout
  title="AI Fund | Governed Financial Intelligence"
  description="AI Fund is a governed recommendation and analytics platform exploring semantic execution, policy-aware validation, and multi-agent financial intelligence systems."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Governed financial intelligence</p>
      <h1>AI Fund</h1>
      <p>
        A governed recommendation and analytics platform exploring semantic planning,
        policy-aware validation, provenance-backed recommendations, and intelligent
        multi-agent financial research systems.
      </p>
      <div class="hero-actions" aria-label="Primary actions">
        <a class="button primary" href="#demo">Run Live Demo</a>
        <a class="button secondary" href="https://github.com/lxjuly/aifund">View GitHub</a>
      </div>
    </div>
    <div class="status-board" aria-label="Current system status">
      <div>
        <span>Semantic Layer</span>
        <strong>Governed Access</strong>
      </div>
      <div>
        <span>Execution</span>
        <strong>Dry Run First</strong>
      </div>
      <div>
        <span>Recommendation</span>
        <strong>Multi-Agent Signals</strong>
      </div>
      <div>
        <span>Deployment</span>
        <strong>Cloudflare Pages</strong>
      </div>
    </div>
  </section>

  <SystemVisual />

  <section class="content-band">
    <div class="section-heading">
      <p class="eyebrow">Platform direction</p>
      <h2>Semantic planning before execution.</h2>
    </div>
    <div class="principle-grid">
      <article>
        <h3>Recommendation infrastructure</h3>
        <p>Candidate retrieval, signal generation, ranking, filtering, and selection are treated as platform primitives.</p>
      </article>
      <article>
        <h3>Governed execution</h3>
        <p>Agent-generated plans are validated through semantic metadata and policy-aware dry runs before execution.</p>
      </article>
      <article>
        <h3>Traceable decisions</h3>
        <p>Recommendations include provenance and execution lineage instead of opaque LLM-only outputs.</p>
      </article>
    </div>
  </section>

  <GovernedDemo />
</BaseLayout>
