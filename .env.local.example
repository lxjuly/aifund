# Local verification environment for TradingAgents execution flow
#
# Copy to .env.local or merge the values you need into .env.
# This file is optimized for dry-run paper-trading verification with a
# Thunder Compute Ollama instance forwarded back to your local machine.

# --------------------------------------------------------------------
# Model / provider configuration
# --------------------------------------------------------------------

# Recommended path:
# 1. Create a Thunder Compute instance with the `ollama` template
# 2. Connect to it so port 11434 forwards to your machine
# 3. Start Ollama on the instance with `start-ollama`
# 4. Run TradingAgents locally against the forwarded endpoint
#
# Thunder's Ollama template forwards the API to http://localhost:11434
# when connected. TradingAgents already supports `ollama` directly.
TRADINGAGENTS_LLM_PROVIDER=ollama
TRADINGAGENTS_BACKEND_URL=http://localhost:11434/v1
TRADINGAGENTS_DEEP_MODEL=llama3.1:70b
TRADINGAGENTS_QUICK_MODEL=llama3.1:70b
TRADINGAGENTS_OUTPUT_LANGUAGE=English

# Optional provider-specific knobs
TRADINGAGENTS_OPENAI_REASONING_EFFORT=
TRADINGAGENTS_GOOGLE_THINKING_LEVEL=
TRADINGAGENTS_ANTHROPIC_EFFORT=

# --------------------------------------------------------------------
# Research / debate depth
# --------------------------------------------------------------------

TRADINGAGENTS_RESEARCH_DEPTH=1
TRADINGAGENTS_RISK_DEPTH=1

# --------------------------------------------------------------------
# Local results and cache locations
# --------------------------------------------------------------------

# Defaults already work if omitted, but these make local runs easier to inspect.
TRADINGAGENTS_RESULTS_DIR=/Users/youmiss/.tradingagents/logs
TRADINGAGENTS_CACHE_DIR=/Users/youmiss/.tradingagents/cache

# --------------------------------------------------------------------
# Execution policy defaults
# --------------------------------------------------------------------

# Comma-separated symbol allowlist for the execution layer.
TRADINGAGENTS_ALLOWED_SYMBOLS=NVDA,SPY,QQQ

# Conservative local defaults.
TRADINGAGENTS_MIN_CONFIDENCE=0.55
TRADINGAGENTS_MAX_NOTIONAL_USD=100
TRADINGAGENTS_MAX_PORTFOLIO_ALLOCATION_PCT=0.10
TRADINGAGENTS_MAX_TOTAL_EXPOSURE_PCT=0.30
TRADINGAGENTS_MAX_SPREAD_PCT=0.01
TRADINGAGENTS_ALLOW_SHORT=false
TRADINGAGENTS_ALLOW_FRACTIONAL=true
TRADINGAGENTS_BLOCK_PDT=true

# Keep this false for local verification unless you intentionally want broker submission.
TRADINGAGENTS_SUBMIT_ORDERS=false

# --------------------------------------------------------------------
# Optional Alpaca paper-trading settings
# --------------------------------------------------------------------

ALPACA_PAPER=true
ALPACA_BASE_URL=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --------------------------------------------------------------------
# Upstream provider keys if needed
# Leave these empty for the Thunder + Ollama path unless you intentionally
# switch to a hosted provider.
# --------------------------------------------------------------------

OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
